#!/bin/sh
set -eu

blocked_files='(^|/)(\.env($|\.)|auth\.json$|opencode-auth\.json$|.*\.(pem|key|p12|pfx|token|secret|credential)$|id_rsa$|id_ed25519$|.*(_rsa|_ed25519)$|(tokens|secrets|credentials)/|[^/]*(token|secret|credential)\.(json|txt|env|yml|yaml|toml|ini)$)'
blocked_content='(sk-[A-Za-z0-9_-]{20,}|ghp_[A-Za-z0-9_]{20,}|github_pat_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |OPENSSH |EC |DSA )?PRIVATE KEY-----)'

staged_files=$(git diff --cached --name-only)

if [ -n "$staged_files" ] && printf '%s\n' "$staged_files" | grep -Eiq "$blocked_files"; then
  echo "Blocked commit: staged file name looks like a secret or credential."
  printf '%s\n' "$staged_files" | grep -Ei "$blocked_files" || true
  echo "Move credentials outside the repo and keep only placeholders or docs."
  exit 1
fi

if git diff --cached --no-ext-diff --unified=0 | grep -Eiq "$blocked_content"; then
  echo "Blocked commit: staged diff appears to contain a private key or access token."
  echo "Remove the secret from the staged change before committing."
  exit 1
fi
